{% extends 'base.html.twig' %}

{% block title %}GameStack - Gestionnaire de jeux{% endblock %}

{% block body %}
<section class="landing-hero">
    <p class="hero-eyebrow">Ta collection, un seul endroit</p>
    <h1 class="hero-title">Bienvenue sur <em>GameStack</em></h1>
    <p class="hero-sub">Gérez votre collection de jeux, suivez vos statuts, vos notes et votre temps de jeu — sans rien perdre.</p>

    {% if app.user %}
        {% if hasSteamAccount %}
            <div class="steam-linked">
                <img src="{{ app.user.steamAccount.avatar }}" width="50" height="50" alt="Avatar Steam">
                <div>
                    <strong>Compte Steam lié</strong><br>
                    <small class="muted">{{ steamGamesCount ?? 0 }} jeux synchronisés</small>
                </div>
            </div>
            <div class="hero-actions">
                <a href="{{ path('app_library') }}" class="btn btn-primary">Voir ma bibliothèque</a>
                <a href="{{ path('app_steam_sync') }}" class="btn btn-ghost">Resynchroniser Steam</a>
            </div>
        {% else %}
            <div class="hero-actions">
                <a href="{{ path('app_steam_login') }}" class="btn-steam">
                    <i class="fab fa-steam"></i> Lier mon compte Steam
                </a>
                <a href="{{ path('app_library') }}" class="btn btn-primary">Gérer mes jeux manuellement</a>
            </div>
        {% endif %}
    {% else %}
        <div class="hero-actions">
            <a href="{{ path('app_register') }}" class="btn btn-primary">Créer un compte</a>
            <a href="{{ path('app_login') }}" class="btn btn-ghost">Se connecter</a>
        </div>
    {% endif %}
</section>

<div class="features">
    <div class="feature">
        <h4>📚 Synchronisation Steam</h4>
        <p>Importez automatiquement tous vos jeux Steam en un clic.</p>
    </div>
    <div class="feature">
        <h4>🎮 Gestion unifiée</h4>
        <p>Vos jeux Steam et manuels dans une seule bibliothèque.</p>
    </div>
    <div class="feature">
        <h4>📊 Suivi détaillé</h4>
        <p>Statuts, temps de jeu, notes personnelles et bien plus.</p>
    </div>
</div>

{% if is_granted('ROLE_ADMIN') %}
<div class="page-shell">
    <div class="home-stats">
        <div class="home-stat">
            <div class="home-stat-value">{{ registeredUsers ?? 0 }}</div>
            <div class="home-stat-label">Utilisateurs inscrits</div>
        </div>
        <div class="home-stat">
            <div class="home-stat-value">{{ onlineUsers ?? 0 }}</div>
            <div class="home-stat-label">Utilisateurs en ligne</div>
        </div>
    </div>
</div>
{% endif %}

{% endblock %}
