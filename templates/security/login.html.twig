{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h2 class="text-center">Connexion</h2>
                    </div>
                    <div class="card-body">
                        {% if error %}
                            <div class="alert alert-danger">
                                {% if error.messageKey == 'Invalid credentials.' %}
                                    Email ou mot de passe incorrect
                                {% else %}
                                    {{ error.messageKey|trans(error.messageData, 'security') }}
                                {% endif %}
                            </div>
                        {% endif %}

                        {% if app.user %}
                            <div class="alert alert-info mb-3">
                                Vous êtes connecté en tant que {{ app.user.userIdentifier }}, 
                                <a href="{{ logout_path() }}" class="alert-link">Déconnexion</a>
                            </div>
                        {% endif %}

                        <form method="post">
                            <div class="mb-3">
                                <label for="username" class="form-label">Email</label>
                                <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
                            </div>
                            
                            <div class="mb-3">
                                <label for="password" class="form-label">Mot de passe</label>
                                <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
                            </div>

                            <div class="d-grid">
                                <button class="btn btn-primary" type="submit">
                                    Se connecter
                                </button>
                            </div>
                        </form>
                        
                        <div class="text-center mt-4">
                            <div class="border-top pt-3">
                                <p class="text-muted mb-2">Ou connectez-vous avec</p>
                                <a href="{{ path('app_steam_login') }}" class="btn btn-steam">
                                    <i class="fab fa-steam me-2"></i>Steam
                                </a>
                            </div>
                        </div>
                        
                        <div class="text-center mt-3">
                            <a href="{{ path('app_password_reset') }}" class="btn btn-link">Mot de passe oublié ?</a>
                            <br>
                            <a href="{{ path('app_register') }}" class="btn btn-link">Créez un compte</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
