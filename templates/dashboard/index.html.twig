{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
    <section class="dashboard">
        <div class="dashboard-hero">
            <p class="dashboard-kicker">Espace admin</p>
            <h1>Dashboard GameStack</h1>
            <p>Vue rapide de l’activité de la plateforme sur une fenêtre de {{ activeWindowMinutes }} minutes.</p>
        </div>

        <div class="dashboard-grid">
            <article class="stat-card">
                <span class="stat-label">Personnes en ligne</span>
                <strong>{{ onlineUsers }}</strong>
                <p>Utilisateurs actifs récemment.</p>
            </article>

            <article class="stat-card">
                <span class="stat-label">Total inscrits</span>
                <strong>{{ registeredUsers }}</strong>
                <p>Comptage global des comptes créés.</p>
            </article>

            <article class="stat-card">
                <span class="stat-label">Administrateurs actifs</span>
                <strong>{{ activeAdministrators }}</strong>
                <p>Admins actifs sur les {{ activeWindowMinutes }} dernières minutes.</p>
            </article>
        </div>

        <div class="dashboard-notes">
            <h2>Les 5 derniers inscrits</h2>

            <div class="recent-users">
                {% for user in latestRegisteredUsers %}
                    <article class="recent-user-card">
                        <div>
                            <strong>{{ user.username ?: 'Sans pseudo' }}</strong>
                            <p>{{ user.email }}</p>
                        </div>
                        <span>{{ user.createdAt ? user.createdAt|date('d/m/Y H:i') : 'Date inconnue' }}</span>
                    </article>
                {% else %}
                    <p>Aucun utilisateur inscrit pour le moment.</p>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}