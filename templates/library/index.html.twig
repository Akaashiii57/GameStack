{% extends 'base.html.twig' %}

{% block title %}Bibliothèque{% endblock %}

{% block body %}
<section class="page-shell">
    <div class="library-head">
        <div>
            <p class="page-eyebrow">Ma collection</p>
            <h1 class="page-title">Bienvenue {{ user.username }} dans ta bibliothèque <em>GameStack</em></h1>
        </div>
        <a href="{{ path('app_library_search') }}" class="btn btn-primary">+ Ajouter un jeu</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}

    {% if libraries is empty %}
        <div class="empty-state">
            <p>Vous n'avez pas encore ajouté de jeux !</p>
        </div>
    {% else %}
        <div class="sort-controls">
            <span>Trier par titre :</span>
            <a href="{{ path('app_library', {sort: 'az'}) }}" class="btn-sort {{ current_sort == 'az' ? 'active' : '' }}">A → Z</a>
            <a href="{{ path('app_library', {sort: 'za'}) }}" class="btn-sort {{ current_sort == 'za' ? 'active' : '' }}">Z → A</a>
        </div>
        
        <div class="wrapper-game">
            {% for lg in libraries %}
                <div class="cardGame">
                    <div class="card-cover">
                        {% if lg.game.cover %}
                            {% if lg.game.cover starts with 'http' %}
                                <img src="{{ lg.game.cover }}" alt="{{ lg.game.title }}">
                            {% else %}
                                <img src="{{ asset('uploads/covers/' ~ lg.game.cover) }}" alt="{{ lg.game.title }}">
                            {% endif %}
                        {% else %}
                            Pas de jaquette
                        {% endif %}
                    </div>
                    <div class="card-content">
                        <span class="card-mode">{{ lg.game.mode }}</span>
                        <h4>{{ lg.game.title }}</h4>
                        <p class="card-desc">{{ lg.game.description ? lg.game.description : 'Aucune description' }}</p>
                        <div class="card-informations">
                            <p><strong>Développeur :</strong> {{ lg.game.developer }}</p>
                            <p><strong>Éditeur :</strong> {{ lg.game.publisher }}</p>
                            {% if lg.game.releaseDate %}
                                <p><strong>Date de sortie :</strong> {{ lg.game.releaseDate|date('d/m/Y') }}</p>
                            {% endif %}

                        </div>
                        <div class="card-actions">
                            <a href="{{ path('app_library_jeu', { id: lg.id }) }}" class="card-cta">Voir le jeu</a>
                            <form method="POST" action="{{ path('app_library_delete', { id: lg.id }) }}" onsubmit="return confirm('Retirer « {{ lg.game.title|e('js') }} » de ta bibliothèque ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ lg.id) }}">
                                <button type="submit" class="card-delete" title="Retirer de ma bibliothèque">Supprimer</button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</section>

<style>
.sort-controls {
    margin: 20px 0;
    display: flex;
    align-items: center;
    gap: 10px;
}

.btn-sort {
    padding: 8px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    text-decoration: none;
    color: var(--text);
    font-size: 14px;
    font-family: var(--font-mono);
    transition: all 0.2s;
}

.btn-sort:hover {
    background: var(--surface-2);
}

.btn-sort.active {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
}

.card-desc {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.4;
    max-height: 2.8em;
}
</style>
{% endblock %}
